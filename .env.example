# THcommunity Docker Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Supabase is required for authentication, database access (PostgREST) and realtime.
# Use the values from your Supabase project (Project Settings -> API).
# The backend still starts without them, but login and data access will not work.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-publishable-key
SUPABASE_SECRET_KEY=your-supabase-service-role-secret-key

# Cloudflare R2 (optional - leave empty to use no-op storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# VAPID / Web Push (optional - leave empty to disable push notifications)
VAPID_SUBJECT=mailto:admin@thcommunity.cz
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Cloud-agnostic auth (optional) ------------------------------------------
# Leave AUTH_PROVIDER empty to keep using Supabase. Set it to validate tokens
# from Azure Entra (AD) or AWS Cognito instead. See README and the dedicated
# .env.azure.example / .env.aws.example files.
#   AUTH_PROVIDER=cognito|azuread|entra|oidc
AUTH_PROVIDER=
AUTH_AUTHORITY=
AUTH_METADATA_ADDRESS=
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_REGION=
AUTH_USER_POOL_ID=
AUTH_TENANT_ID=

# --- Cloud-agnostic object storage (optional) --------------------------------
# AWS S3 native: set STORAGE_REGION and leave STORAGE_SERVICE_URL empty.
# Cloudflare R2 / MinIO: set STORAGE_SERVICE_URL. Falls back to R2_* above.
STORAGE_PROVIDER=
STORAGE_SERVICE_URL=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_PUBLIC_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
