# THcommunity – running on AWS instead of Supabase
# Copy to .env.cloud and fill in your values:
#   cp .env.aws.example .env.cloud
#   docker compose --env-file .env.cloud -f docker-compose.cloud.yml up --build
#
# Database: AWS RDS / Aurora PostgreSQL (managed).
# Auth + data API: self-hosted GoTrue + PostgREST containers (this stack), OR
#                  switch to AWS Cognito by setting the AUTH_* block at the bottom.
# Storage: AWS S3 (native).

# --- Managed PostgreSQL (RDS / Aurora) ---------------------------------------
DB_HOST=your-db.xxxxxxxx.eu-central-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=your-rds-admin-password
DB_SSLMODE=require

# Passwords for the roles created by 000_cloud_bootstrap.sql (CHANGE THESE).
AUTHENTICATOR_PASSWORD=change-me-authenticator
AUTH_ADMIN_PASSWORD=change-me-auth-admin

# --- Shared JWT secret + demo-style keys (HS256) -----------------------------
# Generate the keys (ANON_KEY / SERVICE_KEY) by signing {"role":"anon"} and
# {"role":"service_role"} with JWT_SECRET. See README for the snippet.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=replace-with-anon-jwt-signed-by-JWT_SECRET
SERVICE_KEY=replace-with-service-role-jwt-signed-by-JWT_SECRET

# --- Public URLs (as reachable from the browser) -----------------------------
PUBLIC_AUTH_URL=https://auth.your-domain.com   # nginx gateway (/auth/v1, /rest/v1)
PUBLIC_API_URL=https://api.your-domain.com     # backend
SITE_URL=https://app.your-domain.com           # frontend

# --- SMTP for magic-link e-mails (e.g. Amazon SES) ---------------------------
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-user
SMTP_PASS=your-ses-smtp-password
SMTP_ADMIN_EMAIL=admin@your-domain.com

# --- Object storage: AWS S3 (native) -----------------------------------------
STORAGE_PROVIDER=s3
STORAGE_SERVICE_URL=
STORAGE_REGION=eu-central-1
STORAGE_BUCKET=thcommunity-media
STORAGE_PUBLIC_URL=https://thcommunity-media.s3.eu-central-1.amazonaws.com
STORAGE_ACCESS_KEY=your-aws-access-key-id
STORAGE_SECRET_KEY=your-aws-secret-access-key

# --- Optional: use AWS Cognito instead of the bundled GoTrue -----------------
# Set these on the backend (docker-compose.yml or your container platform) to
# validate Cognito-issued tokens. Then you do not need the auth/rest/gateway
# services for API authentication.
#   AUTH_PROVIDER=cognito
#   AUTH_REGION=eu-central-1
#   AUTH_USER_POOL_ID=eu-central-1_XXXXXXXXX
#   AUTH_AUDIENCE=your-cognito-app-client-id
