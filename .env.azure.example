# THcommunity – running on Azure instead of Supabase
# Copy to .env.cloud and fill in your values:
#   cp .env.azure.example .env.cloud
#   docker compose --env-file .env.cloud -f docker-compose.cloud.yml up --build
#
# Database: Azure Database for PostgreSQL Flexible Server (managed).
# Auth + data API: self-hosted GoTrue + PostgREST containers (this stack), OR
#                  switch to Azure Entra (AD) by setting the AUTH_* block at the bottom.
# Storage: Azure Blob Storage via its S3-compatible endpoint, or AWS S3 / R2.

# --- Managed PostgreSQL (Azure Database for PostgreSQL) -----------------------
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
DB_ADMIN_USER=pgadmin
DB_ADMIN_PASSWORD=your-azure-admin-password
DB_SSLMODE=require

# Passwords for the roles created by 000_cloud_bootstrap.sql (CHANGE THESE).
AUTHENTICATOR_PASSWORD=change-me-authenticator
AUTH_ADMIN_PASSWORD=change-me-auth-admin

# --- Shared JWT secret + demo-style keys (HS256) -----------------------------
# Generate the keys (ANON_KEY / SERVICE_KEY) by signing {"role":"anon"} and
# {"role":"service_role"} with JWT_SECRET. See README for the snippet.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=replace-with-anon-jwt-signed-by-JWT_SECRET
SERVICE_KEY=replace-with-service-role-jwt-signed-by-JWT_SECRET

# --- Public URLs (as reachable from the browser) -----------------------------
PUBLIC_AUTH_URL=https://auth.your-domain.com   # nginx gateway (/auth/v1, /rest/v1)
PUBLIC_API_URL=https://api.your-domain.com     # backend
SITE_URL=https://app.your-domain.com           # frontend

# --- SMTP for magic-link e-mails (e.g. Azure Communication Services) ---------
SMTP_HOST=smtp.azurecomm.net
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=admin@your-domain.com

# --- Object storage ----------------------------------------------------------
# The backend uses the S3 protocol. Point it at any S3-compatible endpoint:
# AWS S3 (native, set STORAGE_REGION only), Cloudflare R2 / MinIO, or an
# Azure Blob S3-compatible gateway. (Native Azure Blob SDK is not used.)
STORAGE_PROVIDER=s3compatible
STORAGE_SERVICE_URL=https://your-s3-compatible-endpoint
STORAGE_REGION=
STORAGE_BUCKET=thcommunity-media
STORAGE_PUBLIC_URL=https://your-public-media-url
STORAGE_ACCESS_KEY=your-access-key-id
STORAGE_SECRET_KEY=your-secret-access-key

# --- Optional: use Azure Entra (AD) instead of the bundled GoTrue ------------
# Set these on the backend to validate Entra-issued tokens. Then you do not need
# the auth/rest/gateway services for API authentication.
#   AUTH_PROVIDER=azuread
#   AUTH_TENANT_ID=your-tenant-id
#   AUTH_AUDIENCE=your-application-client-id
#   # For Entra External ID / B2C user flows, set AUTH_METADATA_ADDRESS instead:
#   # AUTH_METADATA_ADDRESS=https://<tenant>.ciamlogin.com/<tenant>/v2.0/.well-known/openid-configuration
